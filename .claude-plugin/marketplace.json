{
  "$schema": "https://json.schemastore.org/claude-code-marketplace.json",
  "name": "bolt-skills",
  "description": "开发工作流技能合集：需求澄清 → 文档优先 → 依赖管理 → 完成验收",
  "owner": {
    "name": "bolt",
    "email": "github@robolt.uu.me"
  },
  "metadata": {
    "description": "涵盖 spec-first、doc-first、bun-pnpm、done-check 的开发工作流技能合集",
    "version": "1.0.0"
  },
  "plugins": [
    {
      "name": "doc-first",
      "description": "文档优先原则：要求 agent 先写文档、后写代码，代码变更必须同步更新文档。",
      "source": "./",
      "version": "1.0.0",
      "author": {
        "name": "bolt",
        "email": "x.bolt@robolt.uu.me"
      },
      "keywords": [
        "documentation",
        "docs-first",
        "workflow",
        "best-practices",
        "agent-guidelines"
      ],
      "category": "workflow"
    },
    {
      "name": "spec-first",
      "description": "需求澄清与原型确认：要求 agent 先澄清需求、确认原型/方案，获得用户明确认可后再进入编码。",
      "source": "./",
      "version": "1.0.0",
      "author": {
        "name": "bolt",
        "email": "x.bolt@robolt.uu.me"
      },
      "keywords": [
        "requirements",
        "clarification",
        "prototype",
        "spec",
        "workflow",
        "best-practices",
        "agent-guidelines"
      ],
      "category": "workflow"
    },
    {
      "name": "bun-pnpm",
      "description": "Bun 项目使用 pnpm 管理依赖：依赖管理（install/add/remove）一律使用 pnpm，运行时（脚本执行、测试、服务启动）继续使用 bun。",
      "source": "./",
      "version": "1.0.0",
      "author": {
        "name": "bolt",
        "email": "x.bolt@robolt.uu.me"
      },
      "keywords": [
        "bun",
        "bunjs",
        "pnpm",
        "dependency-management",
        "package-manager",
        "workflow",
        "best-practices",
        "agent-guidelines"
      ],
      "category": "tooling"
    },
    {
      "name": "done-check",
      "description": "开发完成验收：要求 agent 在宣告任务完成前执行系统性验收（需求回溯、测试、构建、手动验证、diff 自审、回归排查、文档同步），按 CLI / Web / Server 项目类型区分验收方式，确保变更真正完成。",
      "source": "./",
      "version": "1.0.0",
      "author": {
        "name": "bolt",
        "email": "x.bolt@robolt.uu.me"
      },
      "keywords": [
        "acceptance",
        "verification",
        "testing",
        "qa",
        "definition-of-done",
        "workflow",
        "best-practices",
        "agent-guidelines"
      ],
      "category": "workflow"
    }
  ]
}
