{
  "$schema": "https://json.schemastore.org/claude-code-marketplace.json",
  "name": "doc-first-skills",
  "description": "文档优先原则相关 Claude Code 技能",
  "owner": {
    "name": "bolt",
    "email": "github@robolt.uu.me"
  },
  "metadata": {
    "description": "文档优先原则 Claude Code 技能",
    "version": "1.0.0"
  },
  "plugins": [
    {
      "name": "doc-first",
      "description": "文档优先原则：要求 agent 先写文档、后写代码，代码变更必须同步更新文档。",
      "source": "./",
      "version": "1.0.0",
      "author": {
        "name": "bolt",
        "email": "x.bolt@robolt.uu.me"
      },
      "keywords": [
        "documentation",
        "docs-first",
        "workflow",
        "best-practices",
        "agent-guidelines"
      ],
      "category": "workflow"
    },
    {
      "name": "spec-first",
      "description": "需求澄清与原型确认：要求 agent 先澄清需求、确认原型/方案，获得用户明确认可后再进入编码。",
      "source": "./",
      "version": "1.0.0",
      "author": {
        "name": "bolt",
        "email": "x.bolt@robolt.uu.me"
      },
      "keywords": [
        "requirements",
        "clarification",
        "prototype",
        "spec",
        "workflow",
        "best-practices",
        "agent-guidelines"
      ],
      "category": "workflow"
    },
    {
      "name": "bun-pnpm",
      "description": "Bun 项目使用 pnpm 管理依赖：依赖管理（install/add/remove）一律使用 pnpm，运行时（脚本执行、测试、服务启动）继续使用 bun。",
      "source": "./",
      "version": "1.0.0",
      "author": {
        "name": "bolt",
        "email": "x.bolt@robolt.uu.me"
      },
      "keywords": [
        "bun",
        "bunjs",
        "pnpm",
        "dependency-management",
        "package-manager",
        "workflow",
        "best-practices",
        "agent-guidelines"
      ],
      "category": "tooling"
    }
  ]
}
